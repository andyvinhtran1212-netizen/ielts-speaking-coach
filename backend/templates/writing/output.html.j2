{# Writing Coach feedback HTML render — Sprint 2.5.4 spec.

   Inline styles only — Google Docs strips <style>/<script> on paste,
   so every visual cue lives on a `style="..."` attribute. Tables (not
   CSS grid) for the 1×2 takeaways block + 2×2 criteria grid for the
   same reason.

   Autoescape is enabled by writing_render.py — never use |safe on
   user-supplied fields. The only |safe usage below is on
   highlighted_essay_html which writing_render._build_highlighted_essay_html()
   escapes itself before wrapping the highlighted spans.
#}
<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8" />
<title>{{ task_label }}{% if student_name %} — {{ student_name }}{% endif %}</title>
</head>
<body>
<div style="font-family:'Inter',Calibri,Arial,sans-serif;color:{{ C_BODY }};line-height:1.6;max-width:900px;margin:0 auto;padding:24pt;">

  {# ── 2.1 Title + Overall band ───────────────────────────────── #}
  <h1 style="text-align:center;font-size:24pt;color:{{ C_SUBHEAD }};margin:0 0 12pt;">{{ task_label }}</h1>
  {% if student_name %}
  <p style="text-align:center;color:{{ C_MUTED }};margin:0 0 16pt;font-size:10pt;">{{ student_name }}</p>
  {% endif %}

  <div style="text-align:center;background:{{ C_GRAY_BG }};padding:24pt;margin:16pt 0;border-radius:8pt;">
    <span style="font-size:72pt;color:{{ C_BLUE }};font-weight:bold;">{{ overall_band }}</span>
    <span style="font-size:24pt;color:{{ C_MUTED }};"> / 9.0</span>
  </div>

  {% if overall_summary %}
  <p style="font-style:italic;color:{{ C_BODY }};margin:8pt 0 16pt;">{{ overall_summary }}</p>
  {% endif %}

  {# ── 2.2 Key Takeaways: 1×2 table ────────────────────────────── #}
  <h2 style="color:{{ C_SUBHEAD }};font-size:16pt;margin:24pt 0 8pt;">Key Takeaways</h2>
  <table style="width:100%;border-collapse:collapse;margin-bottom:16pt;">
    <tr>
      <td style="width:50%;vertical-align:top;padding:12pt;background:{{ C_GREEN_BG }};border:1pt solid {{ C_BORDER }};">
        <p style="color:{{ C_GREEN }};font-weight:bold;font-size:12pt;margin:0 0 8pt;">Strengths</p>
        {% if takeaways.strengths %}
        <ul style="margin:0;padding-left:20pt;">
          {% for s in takeaways.strengths %}<li style="margin-bottom:4pt;">{{ s }}</li>{% endfor %}
        </ul>
        {% else %}
        <p style="margin:0;color:{{ C_MUTED }};">—</p>
        {% endif %}
      </td>
      <td style="width:50%;vertical-align:top;padding:12pt;background:{{ C_YELLOW_BG }};border:1pt solid {{ C_BORDER }};">
        <p style="color:{{ C_YELLOW }};font-weight:bold;font-size:12pt;margin:0 0 8pt;">Areas for Improvement</p>
        {% if takeaways.areas_for_improvement %}
        <ul style="margin:0;padding-left:20pt;">
          {% for a in takeaways.areas_for_improvement %}<li style="margin-bottom:4pt;">{{ a }}</li>{% endfor %}
        </ul>
        {% else %}
        <p style="margin:0;color:{{ C_MUTED }};">—</p>
        {% endif %}
      </td>
    </tr>
  </table>

  {# ── 2.3 Criteria Breakdown: 2×2 grid ────────────────────────── #}
  {% if criteria_grid_rows %}
  <h2 style="color:{{ C_SUBHEAD }};font-size:16pt;margin:24pt 0 8pt;">Criteria Breakdown</h2>
  <table style="width:100%;border-collapse:collapse;border:1pt solid {{ C_BORDER }};">
    {% for row in criteria_grid_rows %}
    <tr>
      {% for c in row %}
      <td style="width:50%;vertical-align:top;padding:12pt;border:1pt solid {{ C_BORDER }};">
        <p style="margin:0;">
          <span style="font-weight:bold;color:{{ C_SUBHEAD }};">{{ c.criterion }}</span>
          <span style="float:right;font-size:18pt;color:{{ C_BLUE }};font-weight:bold;">{{ c.band }}</span>
        </p>
        {% if c.summary %}<p style="font-style:italic;color:{{ C_MUTED }};margin:8pt 0;clear:both;">{{ c.summary }}</p>{% endif %}
        {% if c.strengths %}
        <p style="color:{{ C_GREEN }};font-weight:bold;font-size:10pt;margin:8pt 0 4pt;">Strengths</p>
        <ul style="margin:0;padding-left:16pt;">{% for s in c.strengths %}<li style="margin-bottom:2pt;">{{ s }}</li>{% endfor %}</ul>
        {% endif %}
        {% if c.improvements %}
        <p style="color:{{ C_YELLOW }};font-weight:bold;font-size:10pt;margin:8pt 0 4pt;">Improvements</p>
        <ul style="margin:0;padding-left:16pt;">{% for i in c.improvements %}<li style="margin-bottom:2pt;">{{ i }}</li>{% endfor %}</ul>
        {% endif %}
        {% if c.detailed_text and not c.strengths and not c.improvements %}
        <p style="margin:8pt 0 0;">{{ c.detailed_text }}</p>
        {% endif %}
      </td>
      {% endfor %}
    </tr>
    {% endfor %}
  </table>
  {% endif %}

  {# ── 2.4 Original Essay (red-bg highlights) ──────────────────── #}
  <h2 style="color:{{ C_SUBHEAD }};font-size:16pt;margin:24pt 0 8pt;">Original Essay</h2>
  {% if prompt_text %}
  <p style="color:{{ C_MUTED }};font-size:10pt;margin:0 0 8pt;"><strong>Prompt:</strong> {{ prompt_text }}</p>
  {% endif %}
  <div style="padding:12pt;background:#F8FAFC;border-left:3pt solid {{ C_BLUE }};">
    {{ highlighted_essay_html|safe }}
  </div>

  {# ── 2.5 Detailed Issue Analysis: 5-col table ────────────────── #}
  {% if mistakes %}
  <h2 style="color:{{ C_SUBHEAD }};font-size:16pt;margin:24pt 0 8pt;">Detailed Issue Analysis</h2>
  <table style="width:100%;border-collapse:collapse;border:1pt solid {{ C_BORDER }};">
    <thead>
      <tr style="background:{{ C_GRAY_BG }};">
        <th style="padding:8pt;border:1pt solid {{ C_BORDER }};text-align:left;width:3em;">#</th>
        <th style="padding:8pt;border:1pt solid {{ C_BORDER }};text-align:left;">Original</th>
        <th style="padding:8pt;border:1pt solid {{ C_BORDER }};text-align:left;">Type</th>
        <th style="padding:8pt;border:1pt solid {{ C_BORDER }};text-align:left;">Explanation</th>
        <th style="padding:8pt;border:1pt solid {{ C_BORDER }};text-align:left;">Suggestion</th>
      </tr>
    </thead>
    <tbody>
      {% for m in mistakes %}
      <tr>
        <td style="padding:8pt;border:1pt solid {{ C_BORDER }};">{{ loop.index }}</td>
        <td style="padding:8pt;border:1pt solid {{ C_BORDER }};color:{{ C_RED }};font-family:'Consolas',monospace;">{{ m.original }}</td>
        <td style="padding:8pt;border:1pt solid {{ C_BORDER }};color:{{ C_RED }};font-weight:bold;">{{ m.type }}</td>
        <td style="padding:8pt;border:1pt solid {{ C_BORDER }};">{{ m.explanation }}</td>
        <td style="padding:8pt;border:1pt solid {{ C_BORDER }};color:{{ C_GREEN }};font-style:italic;">{{ m.suggestion }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% endif %}

  {# ── 2.6 Advanced Analysis ──────────────────────────────────── #}
  {% if has_advanced %}
  <h2 style="color:{{ C_SUBHEAD }};font-size:16pt;margin:24pt 0 8pt;">Advanced Analysis</h2>

  {# Lexical Upgrade: 3-col table #}
  {% if lexical_upgrades or lexical_summary %}
  <h3 style="color:{{ C_SUBHEAD }};font-size:13pt;margin:16pt 0 8pt;">Vocabulary &amp; Collocation</h3>
  {% if lexical_summary %}<p style="margin:0 0 8pt;">{{ lexical_summary }}</p>{% endif %}
  {% if lexical_upgrades %}
  <table style="width:100%;border-collapse:collapse;border:1pt solid {{ C_BORDER }};">
    <thead>
      <tr style="background:{{ C_GRAY_BG }};">
        <th style="padding:8pt;border:1pt solid {{ C_BORDER }};width:42%;text-align:left;">Original</th>
        <th style="padding:8pt;border:1pt solid {{ C_BORDER }};width:8%;"></th>
        <th style="padding:8pt;border:1pt solid {{ C_BORDER }};width:50%;text-align:left;">Upgrade (Band 8+)</th>
      </tr>
    </thead>
    <tbody>
      {% for u in lexical_upgrades %}
      <tr>
        <td style="padding:8pt;border:1pt solid {{ C_BORDER }};color:{{ C_RED }};font-family:'Consolas',monospace;">{{ u.original }}</td>
        <td style="padding:8pt;border:1pt solid {{ C_BORDER }};text-align:center;">→</td>
        <td style="padding:8pt;border:1pt solid {{ C_BORDER }};color:{{ C_GREEN }};font-family:'Consolas',monospace;">{{ u.upgrade }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% endif %}
  {% endif %}

  {# Sentence Structure #}
  {% if sentence_structures %}
  <h3 style="color:{{ C_SUBHEAD }};font-size:13pt;margin:16pt 0 8pt;">Sentence Structure Analysis</h3>
  {% for s in sentence_structures %}
  <div style="margin-bottom:12pt;padding:8pt;background:#F8FAFC;border-left:2pt solid {{ C_BORDER }};">
    <p style="margin:0 0 4pt;"><b>Original:</b> <span style="color:{{ C_RED }};">{{ s.original }}</span></p>
    <p style="margin:0 0 4pt;"><b>Rewritten:</b> <span style="color:{{ C_GREEN }};">{{ s.improved }}</span></p>
    {% if s.technique %}<p style="margin:0;font-style:italic;color:{{ C_MUTED }};">Technique: {{ s.technique }}</p>{% endif %}
  </div>
  {% endfor %}
  {% endif %}

  {# Idea Development #}
  {% if idea_development_paragraphs %}
  <h3 style="color:{{ C_SUBHEAD }};font-size:13pt;margin:16pt 0 8pt;">Idea Development &amp; Coherence</h3>
  {% for p in idea_development_paragraphs %}
  <p style="margin:12pt 0 4pt;"><b>Paragraph {{ p.index }}:</b> {{ p.heading }}</p>
  {% if p.original %}<p style="margin:0 0 4pt;font-style:italic;color:{{ C_BODY }};">{{ p.original }}</p>{% endif %}
  {% if p.commentary %}<p style="margin:0 0 4pt;">{{ p.commentary }}</p>{% endif %}
  {% if p.suggestion %}<p style="margin:0 0 8pt;"><b style="color:{{ C_GREEN }};">Suggestion:</b> {{ p.suggestion }}</p>{% endif %}
  {% endfor %}
  {% endif %}

  {# Counterargument (Task 2 only) #}
  {% if counterargument %}
  <h3 style="color:{{ C_SUBHEAD }};font-size:13pt;margin:16pt 0 8pt;">Counterargument Analysis</h3>
  {% if counterargument.summary %}<p style="margin:0 0 8pt;">{{ counterargument.summary }}</p>{% endif %}
  {% if counterargument.points %}
  <ul style="margin:0;padding-left:20pt;">
    {% for pt in counterargument.points %}<li style="margin-bottom:4pt;">{{ pt }}</li>{% endfor %}
  </ul>
  {% endif %}
  {% endif %}

  {% endif %}{# /has_advanced #}

  {# ── 2.7 Improved Essay (Band 8.0+) ──────────────────────────── #}
  {% if improved_essay_lines %}
  <h2 style="color:{{ C_SUBHEAD }};font-size:16pt;margin:24pt 0 8pt;">Improved Essay (Band 8.0+)</h2>
  <div style="padding:12pt;background:{{ C_GREEN_BG }};border-left:3pt solid {{ C_GREEN }};">
    {% for line in improved_essay_lines %}
    <p style="margin:0 0 8pt;">{{ line }}</p>
    {% endfor %}
  </div>
  {% endif %}

  {# ── AI Content Analysis (kept from prior render) ───────────── #}
  {% if ai_content %}
  <h2 style="color:{{ C_SUBHEAD }};font-size:16pt;margin:24pt 0 8pt;">AI Content Analysis</h2>
  {% if ai_content.likelihood is not none %}
  <p><b>Likelihood AI-generated:</b> {{ ai_content.likelihood }}%</p>
  {% endif %}
  {% if ai_content.explanation %}<p>{{ ai_content.explanation }}</p>{% endif %}
  {% endif %}

  {# ── Footer ─────────────────────────────────────────────────── #}
  <p style="text-align:center;margin-top:32pt;font-style:italic;font-size:9pt;color:{{ C_MUTED }};">
    Generated by Aver Learning Writing Coach
  </p>

</div>
</body>
</html>
