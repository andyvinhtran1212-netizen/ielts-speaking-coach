# Supabase
SUPABASE_URL=https://nqhrtqspznepmveyurzm.supabase.co
SUPABASE_ANON_KEY=sb_publishable_a_vDrA0c3mT-QlASPW7yhw_YZnUsfT4
SUPABASE_SERVICE_KEY=SUPABASE_SERVICE_KEY=your_supabase_service_key_here
# Railway / Supabase may provide postgres:// or postgresql:// URLs.
# The backend normalizes those to postgresql+asyncpg:// for async SQLAlchemy use.
DATABASE_URL=postgresql+asyncpg://postgres:password@db.your-project.supabase.co:5432/postgres

# AI APIs
ANTHROPIC_API_KEY=your-anthropic-key
GEMINI_API_KEY=your-gemini-key
OPENAI_API_KEY=your-openai-key

# Google Cloud TTS
GOOGLE_APPLICATION_CREDENTIALS=./google-tts-key.json

# App
ENVIRONMENT=development
MAX_SESSIONS_PER_USER_PER_DAY=24
MAX_AUDIO_DURATION_SECONDS=300

# Writing Task 1 prompt images live in the PUBLIC Supabase Storage bucket
# `writing-images` (create out-of-band: Supabase dashboard → Storage →
# New bucket → name `writing-images` → Public ✓). Override the name here
# only if you use a different bucket.
# WRITING_IMAGES_BUCKET=writing-images

# Sprint 11.1 — Listening module (DEBT-LISTENING-MODULE foundation 1/5).
# ELEVENLABS_API_KEY blank until Andy provisions the Creator plan
# ($22/mo). The render endpoint stays 503 + a feature flag (defense in
# depth) holds the gate until both are set.
ELEVENLABS_API_KEY=
LISTENING_AI_RENDER_ENABLED=false
LISTENING_AUDIO_BUCKET=listening-audio
