{
  "name": "ielts-frontend-e2e",
  "version": "0.0.0",
  "private": true,
  "description": "Playwright browser smoke tests (F4). Bounded to frontend/tests/e2e/ \u2014 do NOT import @playwright elsewhere; the rest of the frontend stays zero-dependency.",
  "scripts": {
    "test:e2e": "playwright test",
    "build:css:setup": "npm --prefix tooling/css ci",
    "build:css": "npm run build:css:plusjakarta && npm run build:css:inter",
    "build:css:plusjakarta": "./tooling/css/node_modules/.bin/tailwindcss -c ./tailwind.config.cjs -i ./css/tailwind.src.css -o ./css/tailwind.build.css --minify",
    "build:css:inter": "./tooling/css/node_modules/.bin/tailwindcss -c ./tailwind.config.inter.cjs -i ./css/tailwind.src.css -o ./css/tailwind.inter.css --minify",
    "test:e2e:staging": "playwright test -c playwright.staging.config.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0"
  }
}